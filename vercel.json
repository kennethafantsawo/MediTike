{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run db:generate && next build",
  "installCommand": "bun install",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/refresh-duty",
      "schedule": "0 7 * * 1"
    }
  ],
  "regions": ["fra1"],
  "env": {
    "NEXTAUTH_URL": "@nextauth-url"
  }
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run db:generate && next build",
  "installCommand": "bun install",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refresh-duty",
      "schedule": "0 7 * * 1"
    }
  ],
  "regions": ["fra1"],
  "firewall": {
    "rules": [
      {
        "description": "Block known bot user agents",
        "action": "deny",
        "condition": {
          "type": "user_agent",
          "match": "bot|crawler|spider|scrap|hack|exploit|sqlmap|nikto|nmap|masscan|wpscan|dirb|gobuster",
          "options": {
            "caseSensitive": false
          }
        }
      },
      {
        "description": "Rate limit API auth (brute force protection)",
        "action": "rateLimit",
        "condition": {
          "type": "path",
          "match": "/api/auth"
        },
        "options": {
          "maxRequests": 10,
          "window": 60
        }
      },
      {
        "description": "Rate limit photo uploads (abuse prevention)",
        "action": "rateLimit",
        "condition": {
          "type": "path",
          "match": "/api/photos/upload"
        },
        "options": {
          "maxRequests": 20,
          "window": 60
        }
      },
      {
        "description": "Rate limit request creation (spam prevention)",
        "action": "rateLimit",
        "condition": {
          "type": "path",
          "match": "/api/requests"
        },
        "options": {
          "maxRequests": 30,
          "window": 60
        }
      },
      {
        "description": "Block requests from known malicious IPs (empty referer on POST)",
        "action": "challenge",
        "condition": {
          "type": "method",
          "match": "POST"
        }
      }
    ]
  }
}

// MediTike — Schéma Prisma (projet sérieux v2)
// Plateforme de demande de médicaments auprès des pharmacies du Togo

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  passwordHash String
  fullName     String?
  role         String   @default("client") // "client" | "pharmacist" | "admin"
  pharmacyId   String?
  pharmacy     Pharmacy? @relation(fields: [pharmacyId], references: [id])
  isActive     Boolean  @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  productRequests  ProductRequest[]
  productResponses ProductResponse[]
  auditLogs        AuditLog[]
}

model Pharmacy {
  id           String   @id @default(cuid())
  name         String
  phone1       String
  phone2       String?
  whatsapp     String?
  address      String?
  city         String   @default("Lomé")
  district     String?
  isActive     Boolean  @default(true)
  createdById  String?  // admin who created it
  createdByName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users           User[]
  dutySchedules   PharmacyDuty[]
  productResponses ProductResponse[]
}

// Pharmacies de garde hebdomadaires (import du fichier xlsx du Ministère)
model PharmacyDuty {
  id          String   @id @default(cuid())
  pharmacyId  String?  // link to registered pharmacy if matched by name
  pharmacy    Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  name        String   // raw name from xlsx
  address     String?  // raw address from xlsx
  phone1      String?
  phone2      String?
  weekStart   DateTime // Monday 00:00 UTC
  weekEnd     DateTime  // next Monday 00:00 UTC
  sourceFile  String?  // filename of the xlsx/json imported
  importedAt  DateTime @default(now())

  @@unique([name, weekStart])
  @@index([weekStart])
}

// Demande client (produit recherché)
model ProductRequest {
  id           String   @id @default(cuid())
  clientId     String
  client       User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productName  String   // médicament demandé
  note         String?  // note optionnelle du client
  status       String   @default("open") // "open" | "responded" | "expired" | "closed"
  clientName   String?
  clientPhone  String?
  photos       Photo[]
  responses    ProductResponse[]
  notifiedPharmacies Int @default(0) // nombre de pharmacies notifiées
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime? // 7 jours après création si pas de réponse

  @@index([status])
  @@index([createdAt])
}

// Réponse pharmacien
model ProductResponse {
  id            String   @id @default(cuid())
  requestId     String
  request       ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  pharmacistId  String
  pharmacist    User     @relation(fields: [pharmacistId], references: [id])
  pharmacyId    String
  pharmacy      Pharmacy @relation(fields: [pharmacyId], references: [id])
  available     Boolean
  price         Float?   // FCFA
  note          String?
  read          Boolean  @default(false) // client a-t-il vu la réponse ?
  createdAt     DateTime @default(now())

  @@index([requestId])
  @@index([pharmacistId])
}

// Photos attachées aux demandes — auto-suppression programmée
model Photo {
  id           String   @id @default(cuid())
  requestId    String
  request      ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  filename     String   // nom du fichier sur disque (hashé)
  originalName String
  mimeType     String
  size         Int      // bytes
  sha256       String   // hash pour intégrité
  uploadedAt   DateTime @default(now())
  deleteAt     DateTime // calculé : 72h après réponse OU 7j après création si pas de réponse
  deletedAt    DateTime? // null = encore présent, date = supprimé

  @@index([deleteAt])
  @@index([requestId])
}

// Journal d'audit admin (toutes les actions sensibles)
model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  action    String   // "create_pharmacy" | "delete_pharmacy" | "import_duty" | "create_admin" | ...
  details   String?  // JSON string
  ip        String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// Statistiques agrégées (cache pour admin dashboard)
model AppStat {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Int
  updatedAt DateTime @updatedAt
}

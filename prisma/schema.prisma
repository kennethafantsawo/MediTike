// MediTike Prisma schema
// Health marketplace for Togo pharmacies

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  passwordHash String
  fullName     String?
  role         String   @default("client") // "client" | "pharmacist" | "admin"
  pharmacyId   String?
  pharmacy     Pharmacy? @relation(fields: [pharmacyId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  searchRequests  SearchRequest[]
  searchResponses SearchResponse[]
}

model Pharmacy {
  id          String   @id @default(cuid())
  name        String
  phone       String
  whatsapp    String?
  address     String
  city        String   @default("Lomé")
  district    String?  // Quartier
  latitude    Float?
  longitude   Float?
  openingHours String? // e.g. "08:00-22:00"
  imageUrl    String?
  isOpen24h   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          User[]
  stocks         PharmacyStock[]
  dutySchedules  DutySchedule[]
  searchResponses SearchResponse[]
}

model Medication {
  id          String   @id @default(cuid())
  name        String
  normalizedName String
  genericName String?
  category    String?  // e.g. "Antibiotique", "Antalgique"
  form        String?  // "Comprimé", "Sirop", "Injectable"
  dosage      String?  // "500mg"
  description String?
  createdAt   DateTime @default(now())

  stocks PharmacyStock[]
}

model PharmacyStock {
  id           String   @id @default(cuid())
  pharmacyId   String
  medicationId String
  pharmacy     Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  inStock      Boolean  @default(true)
  price        Float?   // Price in FCFA (XOF)
  lastVerified DateTime @default(now())

  @@unique([pharmacyId, medicationId])
}

model SearchRequest {
  id           String   @id @default(cuid())
  clientId     String
  client       User     @relation(fields: [clientId], references: [id])
  query        String   // Free text searched by user
  normalizedQuery String
  status       String   @default("pending") // "pending" | "resolved" | "expired"
  clientName   String?
  clientPhone  String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime?

  responses SearchResponse[]
}

model SearchResponse {
  id            String   @id @default(cuid())
  requestId     String
  request       SearchRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  pharmacistId  String?
  pharmacist    User?    @relation(fields: [pharmacistId], references: [id])
  pharmacyId    String
  pharmacy      Pharmacy @relation(fields: [pharmacyId], references: [id])
  available     Boolean
  price         Float?   // FCFA
  note          String?
  createdAt     DateTime @default(now())
}

model DutySchedule {
  id          String   @id @default(cuid())
  pharmacyId  String
  pharmacy    Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String   // "08:00"
  endTime     String   // "22:00"
  isDay       Boolean  @default(true) // true = day shift, false = night shift
  createdAt   DateTime @default(now())

  @@unique([pharmacyId, date])
}

model AppStats {
  id           String   @id @default(cuid())
  key          String   @unique
  value        Int
  updatedAt    DateTime @updatedAt
}
